# Runtime modes:
# - Bot-only mode: DISCORD_TOKEN required. Run: python bot.py
# - Web API only (local dev): PORT optional. Run: python web_api/server.py
#   Note: protected endpoints require GODFORGE_ADMIN_PASSWORD.
# - Combined Railway mode: all vars required. Run: python railway_app.py
# WARNING: GODFORGE_ADMIN_PASSWORD=change_me_for_dashboard is a placeholder; change it or dashboard auth will fail.

# Copy this to .env and fill in your values.
# Bot token: https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Standalone party state (optional; defaults shown)
GODFORGE_PARTY_DB_PATH=data/godforge_party.db

# Optional companion compatibility. Leave disabled for standalone GodForge.
GODFORGE_ENABLE_FORGELENS=false

# Betting system channel IDs (right-click channel → Copy ID in Discord)
# DEPRECATED — ignored unless GODFORGE_ENABLE_LEGACY_ECONOMY=true.
BETTING_LEDGER_CHANNEL_ID=1499551914398842900   # #betting-ledger
PLACE_BETS_CHANNEL_ID=1499552266611458209       # #place-bets
MATCH_DRAFT_CHANNEL_ID=0                        # handshake channel; 0 = fallback to any channel named *handshake*

# Activity backend for the draft system
ACTIVITY_BACKEND_URL=                           # e.g. https://your-backend.example.com
ACTIVITY_API_KEY=                               # API key for the Activity backend

# Temporary private dashboard gate. Replace with Discord OAuth later.
GODFORGE_ADMIN_PASSWORD=change_me_for_dashboard

# Discord OAuth (required for dashboard Discord login)
DISCORD_CLIENT_ID=                              # Discord application client ID
DISCORD_CLIENT_SECRET=                          # Discord application client secret — never commit this
DISCORD_OAUTH_REDIRECT_URI=                     # e.g. https://godforge-hub.up.railway.app/api/auth/discord/callback

# Single-tenant routing — replace with your own Discord IDs before deploying
GODFORGE_OWNER_USER_ID=0                # Discord user ID with elevated bot privileges (0 = disabled)
GODFORGE_REPORTS_CHANNELS=              # Comma-separated guild_id:channel_id pairs, e.g. 111:222,333:444

# Dashboard security — required for production
GODFORGE_ALLOWED_ORIGIN=                # Origin allowed to call the API, e.g. https://your-app.railway.app (unset = reflects any origin)
GODFORGE_SESSION_SECRET=                # Random secret for signing session tokens (falls back to insecure default if unset)

# Dashboard storage (optional — defaults to JSON files in data/)
GODFORGE_STORAGE=                       # Set to "sqlite" to use SQLite for dashboard document storage
GODFORGE_DB_PATH=                       # SQLite DB path (default: data/godforge_dashboard.db)

